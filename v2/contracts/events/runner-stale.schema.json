{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cowork.os/contracts/events/runner-stale.schema.json",
  "title": "RunnerStale",
  "type": "object",
  "additionalProperties": false,
  "required": ["runnerId"],
  "properties": {
    "runnerId": { "type": "string" },
