# Copy this file to the repo root as `.env.mac` (gitignored) and fill in values
# only when you want a signed + notarized macOS release.
#
# Unsigned fallback build:
# npm run package:mac:unsigned
#
# Signed + notarized build:
# npm run package:mac
#
# GitHub Actions release builds use the same variable names as repository
# secrets. For App Store Connect API keys in CI, prefer APPLE_API_KEY_BASE64
# or APPLE_API_KEY_CONTENT so scripts/prepare_macos_signing_ci.mjs can write
# the private key to a temporary .p8 file before electron-builder runs.

# --- Code signing (required for distribution outside Mac App Store) ---
# Install "Developer ID Application" from developer.apple.com → Certificates.
# Pin the exact name from Keychain Access if you have several certs:
# CSC_NAME=Developer ID Application: Your Name (TEAMID)
# CI usually uses an exported Developer ID Application .p12:
# CSC_LINK=<base64-encoded .p12 or secure URL>
# CSC_KEY_PASSWORD=<p12 password>

# --- Notarization — option A: Apple ID + app-specific password (common) ---
# Create app-specific password at https://appleid.apple.com → Sign-In and Security
# APPLE_ID=you@example.com
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_TEAM_ID=XXXXXXXXXX

# --- Notarization — option B: App Store Connect API key (recommended for CI) ---
# APPLE_API_KEY=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
# APPLE_API_KEY_BASE64=<base64-encoded AuthKey_XXXXXXXXXX.p8 for CI>
# APPLE_API_KEY_CONTENT=<raw AuthKey_XXXXXXXXXX.p8 contents for CI>
# APPLE_API_KEY_ID=XXXXXXXXXX
# APPLE_API_ISSUER=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Notarization — option C: notarytool stored credentials ---
# APPLE_KEYCHAIN_PROFILE=your-notarytool-profile-name
