ke-linejoin="round" class="lucide lucide-bot" aria-hidden="true"><path d="M12 8V4H8"></path><rect width="16" height="12" x="4" y="8" rx="2"></rect><path d="M2 14h2"></path><path d="M20 14h2"></path><path d="M15 13v2"></path><path d="M9 13v2"></path></svg></span><span class="stream-agent-name-inline" style="color:#6366f1">Researcher</span></div><div class="thought-bubble"><div class="thought-content markdown-content"><p>Drafting summary and preparing next actions.</p></div><div class="thought-footer"><span class="thought-time">02:55 PM</span></div></div></div></div></div><div class="collab-phase-status"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-loader-circle collab-phase-spinner" aria-hidden="true"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg><span class="collab-phase-label">1 agent working...</span></div><div></div></div>"`;

