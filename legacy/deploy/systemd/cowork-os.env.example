# Persistent data directory (DB + encrypted settings)
COWORK_USER_DATA_DIR=/var/lib/cowork-os

# Optional: IANA timezone (e.g. America/New_York, Europe/London) for cron, timestamps, scheduling
# COWORK_TZ=America/New_York

# Control Plane defaults (keep host loopback-only; use SSH tunnel or Tailscale for remote access)
COWORK_CONTROL_PLANE_ENABLE=1
COWORK_CONTROL_PLANE_HOST=127.0.0.1
COWORK_CONTROL_PLANE_PORT=18789
# Managed/headless deployments fail closed on public Control Plane binds by default.
COWORK_MANAGED_DEPLOYMENT=1
# Keep this unset for normal VPS/systemd installs. Containers set it when host publishing is private.
# COWORK_CONTROL_PLANE_BIND_CONTEXT=container
# Only enable behind a trusted reverse proxy that controls forwarded headers.
# COWORK_CONTROL_PLANE_TRUST_PROXY=0
# Comma-separated browser origins allowed to open Control Plane WebSocket connections.
# COWORK_CONTROL_PLANE_ALLOWED_ORIGINS=https://cowork.example.com
# Break-glass only: allows 0.0.0.0/:: public bind without Tailscale/container context.
# COWORK_CONTROL_PLANE_ALLOW_INSECURE_PUBLIC_BIND=0

# Optional: bootstrap a default workspace on startup (create a workspace record if missing)
# COWORK_BOOTSTRAP_WORKSPACE_PATH=/srv/cowork/workspace
# COWORK_BOOTSTRAP_WORKSPACE_NAME=main

# Optional: print the Control Plane token at startup (avoid enabling on shared machines)
# COWORK_PRINT_CONTROL_PLANE_TOKEN=0

# Optional (recommended for headless): import provider creds from env into secure Settings.
# This runs on startup and fills missing Settings fields by default.
COWORK_IMPORT_ENV_SETTINGS=1
# COWORK_IMPORT_ENV_SETTINGS_MODE=merge   # merge|overwrite
# COWORK_LLM_PROVIDER=openai              # openai|anthropic|gemini|...

# LLM provider keys (examples)
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...
# GEMINI_API_KEY=...
